# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/cipherlock

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000

# Rate limiting
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=100

# JWT — used only by the optional admin guard on /api/analytics and /api/report (see README)
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=1h
ADMIN_ROUTES_PROTECTED=false

# Have I Been Pwned Pwned Passwords API
HIBP_API_BASE_URL=https://api.pwnedpasswords.com/range
HIBP_REQUEST_TIMEOUT_MS=5000

# Logging
LOG_LEVEL=info
